      "Map": {
        "S": "Single (one gift ever)",
        "M": "Multi (give more then one gift)",
        "X": "N/A"
      }
    },
    "MonetaryCode": {
      "Position": 8,
      "Map": {
        "A": "$0",
        "B": "$0.01 -$4.99",
        "C": "$5-$9.99",
        "D": "$10-$14.99",
        "E": "$15-$24.99",
        "F": "$25-$49.99",
        "G": "$50-$99.99",
        "H": "$100-$249.99",
        "J": "$250-$499.99",
        "K": "$500-$999.99",
        "L": "$1,000-4,999.99",
        "M": "$5000+"
      }
    }
